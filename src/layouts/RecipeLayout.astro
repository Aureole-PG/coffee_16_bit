---
import Layout from './Layout.astro';
import Button from '../components/ui/Button.astro';
import Text from '../components/ui/Text.astro';
interface Props {
  title: string;
  backHref?: string;
  startHref: string;
  backLabel?: string;
  startLabel?: string;
}

const {
  title,
  backHref = '/recetas',
  startHref,
  backLabel = 'BACK',
  startLabel = 'START',
} = Astro.props;
---

<Layout title={title}>
  <div class="flex flex-col h-screen w-full">
    <main class="flex-1 min-h-0 overflow-y-auto">
      <div class="max-w-5xl mx-auto w-full p-4 md:p-8">
        <slot />
      </div>
    </main>

    <footer class="flex-none  px-4 py-3 md:px-8 md:py-4 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
      <div class="max-w-5xl mx-auto w-full flex gap-3">
        <Button href={backHref} variant="secondary" size="lg" class="flex-1 text-center">
          <Text variant="subtitle" class="text-md">{backLabel}</Text>
        </Button>
        <Button href={startHref} variant="primary" size="lg" class="flex-1 text-center">
          <Text variant="subtitle" class="text-md">{startLabel}</Text>
        </Button>
      </div>
    </footer>
  </div>
</Layout>

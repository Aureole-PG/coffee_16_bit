---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const variants = {
  primary: {
    '--btn-bg': '#FCB5B7',
    '--btn-fg': '#311E1E',
    '--btn-highlight': '#FFE4E6',
    '--btn-shadow': '#8B6465',
    '--btn-border': '#311E1E',
  },
  secondary: {
    '--btn-bg': '#546581',
    '--btn-fg': '#FCB5B7',
    '--btn-highlight': '#6D7A94',
    '--btn-shadow': '#2A374D',
    '--btn-border': '#8B6465',
  },
  danger: {
    '--btn-bg': '#8B6465',
    '--btn-fg': '#FFECEC',
    '--btn-highlight': '#A97D7F',
    '--btn-shadow': '#532F31',
    '--btn-border': '#311E1E',
  },
} as const;

const sizes = {
  sm: {
    outerPadding: 'calc(var(--pixel-border) * 0.75)',
    innerPadding: '0.55rem 1.25rem',
    fontSize: '0.55rem',
  },
  md: {
    outerPadding: 'var(--pixel-border)',
    innerPadding: '0.75rem 1.75rem',
    fontSize: '0.65rem',
  },
  lg: {
    outerPadding: 'calc(var(--pixel-border) * 1.25)',
    innerPadding: '1rem 2.25rem',
    fontSize: '0.75rem',
  },
} as const;

const variantVars = Object.entries(variants[variant])
  .map(([key, value]) => `${key}: ${value}`)
  .join('; ');

const sizeVars = sizes[size];
const classes = `pixel-button ${className}`.trim();
---
{href ? (
  <a
    href={href}
    class={classes}
    style={`--pixel-border: 8px; --outer-padding: ${sizeVars.outerPadding}; --inner-padding: ${sizeVars.innerPadding}; --font-size: ${sizeVars.fontSize}; ${variantVars}`}
  >
    <span class="pixel-button__inner">
      <span class="pixel-button__shine" aria-hidden="true" />
      <slot />
    </span>
  </a>
) : (
  <button
    class={classes}
    style={`--pixel-border: 8px; --outer-padding: ${sizeVars.outerPadding}; --inner-padding: ${sizeVars.innerPadding}; --font-size: ${sizeVars.fontSize}; ${variantVars}`}
  >
    <span class="pixel-button__inner">
      <span class="pixel-button__shine" aria-hidden="true" />
      <slot />
    </span>
  </button>
)}

<style>
  .pixel-button {
    position: relative;
    display: inline-block;
    padding: var(--outer-padding);
    background: var(--btn-border);
    color: inherit;
    text-decoration: none;
    clip-path: polygon(
      var(--pixel-border) 0,
      calc(100% - var(--pixel-border)) 0,
      100% var(--pixel-border),
      100% calc(100% - var(--pixel-border)),
      calc(100% - var(--pixel-border)) 100%,
      var(--pixel-border) 100%,
      0 calc(100% - var(--pixel-border)),
      0 var(--pixel-border)
    );
    transition: transform 80ms ease-out;
  }

  .pixel-button__inner {
    position: relative;
    display: block;
    padding: var(--inner-padding);
    background: var(--btn-bg);
    color: var(--btn-fg);
    font-family: ui-monospace, 'Courier New', 'Consolas', monospace;
    font-size: var(--font-size);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    clip-path: polygon(
      6px 0,
      calc(100% - 6px) 0,
      100% 6px,
      100% calc(100% - 6px),
      calc(100% - 6px) 100%,
      6px 100%,
      0 calc(100% - 6px),
      0 6px
    );
    box-shadow:
      inset -6px -6px 0 var(--btn-shadow),
      inset 6px 6px 0 rgba(255, 255, 255, 0.25),
      6px 6px 0 var(--btn-border);
    transition: transform 80ms ease-out, box-shadow 80ms ease-out;
    overflow: hidden;
  }

  .pixel-button__shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.5) 0%,
      transparent 45%,
      transparent 100%
    );
    clip-path: inherit;
    opacity: 0.35;
    transition: opacity 120ms ease-out;
  }

  .pixel-button:hover .pixel-button__shine {
    opacity: 0.55;
  }

  .pixel-button:hover .pixel-button__inner {
    transform: translate(3px, 3px);
    box-shadow:
      inset -6px -6px 0 var(--btn-shadow),
      inset 6px 6px 0 rgba(255, 255, 255, 0.18),
      4px 4px 0 var(--btn-border);
  }

  .pixel-button:active .pixel-button__inner,
  .pixel-button:focus-visible .pixel-button__inner {
    transform: translate(6px, 6px);
    box-shadow:
      inset 6px 6px 0 var(--btn-shadow),
      inset -6px -6px 0 rgba(0, 0, 0, 0.25),
      0 0 0 var(--btn-border);
  }

  .pixel-button:focus-visible {
    outline: 2px dashed var(--btn-highlight);
    outline-offset: 4px;
  }

  .pixel-button:active .pixel-button__shine {
    opacity: 0.2;
  }
</style>
